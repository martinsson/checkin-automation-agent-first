# Base path the Astro site is served under (Astro `base`).
# Consumed by `make deploy-site` (SITE_BASE) and astro.config.mjs.
#
#   /cocon  — current: served at rental.changit.fr/cocon/
#   /       — future: own domain (cocon-grenoble.fr) at the root
SITE_BASE=/cocon

# The contact form POSTs to the self-hosted endpoint /cocon/api/contact
# (this repo's FastAPI app on :8001, behind Caddy). It emails the message
# via the existing EMAIL_* SMTP settings to CONTACT_RECIPIENT — no third party.
