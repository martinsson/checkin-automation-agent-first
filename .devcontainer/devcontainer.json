{
  "name": "Checkin Automation",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",

  "forwardPorts": [8001],
  "portsAttributes": {
    "8001": {
      "label": "Review UI",
      "onAutoForward": "openBrowser"
    }
  },

  "postCreateCommand": "pip install -r requirements.txt && mkdir -p data",

  "postStartCommand": "bash scripts/codespace-start.sh &",

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python"
      }
    }
  },

  "remoteEnv": {
    "DRY_RUN": "false"
  }
}
