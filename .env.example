# Web UI
REVIEW_TOKEN=
DB_PATH=/data/checkin.db

# Smoobu
SMOOBU_API_KEY=
SMOOBU_WEBHOOK_SECRET=
SMOOBU_APARTMENT_ID=

# Daemon process settings
POLL_INTERVAL=60
LOOKAHEAD_DAYS=14
# DB_PATH=data/checkin.db  # local default; overridden to /data/checkin.db by docker-compose.yml

# AI
ANTHROPIC_API_KEY=

# Trello
TRELLO_API_KEY=
TRELLO_API_TOKEN=
TRELLO_BOARD_ID=
TRELLO_LIST_URGENT=
TRELLO_LIST_NORMAL=

# Door locks
REMOTELOCK_API_KEY=
# Igloohome via Make: URL of the Make custom webhook that creates a PIN code
# (see docs/make/README.md). Optional API key if the webhook uses Make's
# "API key" authentication.
MAKE_IGLOOHOME_WEBHOOK_URL=
MAKE_IGLOOHOME_API_KEY=

# Cleaner communication channel: "email" or "console"
CLEANING_STAFF_CHANNEL=email

# System email (sends queries to cleaner, polls for replies)
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_IMAP_HOST=imap.gmail.com
EMAIL_IMAP_PORT=993

# Cleaner email (receives queries, sends replies)
CLEANER_EMAIL=

# Cleaner account credentials (only needed for integration tests —
# the test uses this account to programmatically send replies)
CLEANER_EMAIL_PASSWORD=

# Testing
TEST_BOOKING_ID=127707687
